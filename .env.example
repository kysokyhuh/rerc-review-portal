# ── Backend ──────────────────────────────────────────────────
# PostgreSQL connection (Neon free tier recommended)
# For the first Render + Neon test deploy, use the direct Neon URL here.
# Add pooling later only after runtime and migration URLs are split.
DATABASE_URL=postgresql://user:password@host:5432/rerc?schema=public

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ISSUER=urerb-review-portal
JWT_AUDIENCE=urerb-review-portal-users

# Server
PORT=3000
NODE_ENV=development
DEV_HEADER_AUTH=false

# CORS — comma-separated origins allowed to call the API
# Example deploy value: https://rerc-web.onrender.com
CORS_ORIGINS=http://localhost:5173

# ── Frontend (Vite) ─────────────────────────────────────────
# API base URL injected at build time
# Example deploy value: https://rerc-api.onrender.com
VITE_API_URL=http://localhost:3000

# Import controls
IMPORT_MAX_ROWS=5000
IMPORT_MAX_FIELD_LENGTH=5000
IMPORT_MAX_RECORD_SIZE=200000
IMPORT_BATCH_SIZE=250

# Seeded account passwords (backend seed)
SEED_CHAIR_PASSWORD=changeme123
SEED_ASSOC_PASSWORD=changeme123
SEED_ASSIST_PASSWORD=changeme123
